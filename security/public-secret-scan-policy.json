{
  "allowedPublicMaterial": [
    "trust/public-release-signing-keys.json",
    "generated/public-release.promotion.json"
  ],
  "assignmentKeyPattern": "(?:SECRET|TOKEN|PASSWORD|PRIVATE_KEY|CLIENT_SECRET|ACCESS_KEY|HMAC|SIGNING_KEY|OPERATOR_SALT)",
  "excludedPathPrefixes": [
    "node_modules/",
    ".nuxt/",
    ".output/",
    "dist/",
    ".git/",
    ".cache/"
  ],
  "forbiddenCredentialBasenames": [
    ".env",
    ".dev.vars",
    ".clasp.json",
    ".clasprc.json",
    "service-account.json",
    "signing-key.json"
  ],
  "forbiddenCredentialSuffixes": [
    ".pem",
    ".key",
    ".p12",
    ".pfx"
  ],
  "forbiddenPathPrefixes": [
    "apps-script/",
    "workers/",
    "content/",
    "artifacts/",
    "fixtures/",
    "docs/",
    ".build/",
    "security/mmj-05n-e/"
  ],
  "maxTextBytes": 2097152,
  "minimumAssignmentSecretLength": 16,
  "placeholderPrefixes": [
    "fixture-",
    "example-",
    "test-",
    "dummy-",
    "placeholder-"
  ],
  "placeholderValues": [
    "",
    "configured",
    "missing",
    "unknown",
    "unset",
    "redacted",
    "example",
    "example-only",
    "replace_me",
    "changeme",
    "test",
    "dummy",
    "placeholder",
    "<secret>",
    "${secret}"
  ],
  "policyId": "mmj-05n-e-public-secret-scan-v1",
  "schemaVersion": 1,
  "secretPatterns": [
    {
      "credentialClass": "S4",
      "expression": "-----BEGIN (?:RSA |EC |OPENSSH |DSA |ENCRYPTED )?PRIVATE KEY-----\\s*[A-Za-z0-9+/=\\r\\n]{32,}\\s*-----END (?:RSA |EC |OPENSSH |DSA |ENCRYPTED )?PRIVATE KEY-----",
      "patternId": "private-key-pem"
    },
    {
      "credentialClass": "S3",
      "expression": "(?:github_pat_[A-Za-z0-9_]{20,}|gh[pousr]_[A-Za-z0-9]{20,})",
      "patternId": "github-token"
    },
    {
      "credentialClass": "S3",
      "expression": "(?:AKIA|ASIA)[A-Z0-9]{16}",
      "patternId": "aws-access-key"
    },
    {
      "credentialClass": "S2",
      "expression": "AIza[0-9A-Za-z_-]{35}",
      "patternId": "google-api-key"
    },
    {
      "credentialClass": "S4",
      "expression": "[\"\\']private_key[\"\\']\\s*:\\s*[\"\\']-----BEGIN PRIVATE KEY-----\\\\n[A-Za-z0-9+/=\\\\n]{32,}",
      "patternId": "google-service-private-key"
    },
    {
      "credentialClass": "S3",
      "expression": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
      "patternId": "jwt-like-token"
    }
  ],
  "sensitiveIdentifierPatterns": [
    {
      "credentialClass": "I2",
      "expression": "account_id\\s*=\\s*[\"\\'][a-f0-9]{32}[\"\\']",
      "patternId": "cloudflare-account-id"
    },
    {
      "credentialClass": "I2",
      "expression": "bucket_name\\s*=\\s*[\"\\'][^\"\\']*(?:private|draft|ingest)[^\"\\']*[\"\\']",
      "patternId": "private-r2-bucket-name"
    },
    {
      "credentialClass": "I2",
      "expression": "(?:spreadsheetId|SPREADSHEET_ID)[\"\\']?\\s*[:=]\\s*[\"\\']1[A-Za-z0-9_-]{24,}[\"\\']",
      "patternId": "literal-spreadsheet-id"
    },
    {
      "credentialClass": "I2",
      "expression": "(?:scriptId|SCRIPT_ID)[\"\\']?\\s*[:=]\\s*[\"\\'][A-Za-z0-9_-]{30,}[\"\\']",
      "patternId": "literal-apps-script-id"
    }
  ]
}
